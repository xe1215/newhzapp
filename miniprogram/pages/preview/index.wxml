<view class="page">
  <view class="title">Free preview</view>
  <view class="copy">Review the current watermarked set before paying to unlock details.</view>
  <view class="preview-grid">
    <view class="preview-card">Look 1</view>
    <view class="preview-card">Look 2</view>
    <view class="preview-card">Look 3</view>
  </view>
  <button class="primary-button" bindtap="unlockReport">Unlock report</button>
  <button class="secondary-button" bindtap="regeneratePreview">Try another set</button>
</view>
