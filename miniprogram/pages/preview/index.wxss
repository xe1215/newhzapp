@import "../shared.wxss";

.preview-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin: 36rpx 0;
}

.preview-card {
  min-height: 260rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #fff;
  border: 1rpx solid #f0d2dc;
}

.preview-image {
  display: block;
  width: 100%;
  height: 220rpx;
  background: #f8dfe7;
}

.shade-name {
  padding: 12rpx 8rpx;
  color: #8b2a4a;
  font-size: 22rpx;
  line-height: 30rpx;
  text-align: center;
}

.preview-state {
  margin: 36rpx 0;
  min-height: 220rpx;
  border-radius: 8rpx;
  background: #f8dfe7;
  color: #8b2a4a;
  font-size: 26rpx;
  line-height: 220rpx;
  text-align: center;
}
